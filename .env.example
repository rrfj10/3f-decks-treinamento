# ─────────────────────────────────────────────────────────────────────────────
# Este arquivo tem DOIS grupos, com donos diferentes.
#
# 1) Configuracao de boot (ate TRUST_PROXY): quem define e o operador. No Docker
#    ela tambem vai no compose, e o valor do ambiente tem prioridade.
#
# 2) Configuracao de LLM (dai para baixo): quem define e a propria tela de
#    configuracao do gerador, que REESCREVE este arquivo ao salvar. Por isso o
#    arquivo vence o ambiente nesse grupo, e por isso essas chaves NAO devem ser
#    declaradas no docker-compose: o redeploy reimporia o valor antigo por cima
#    do que foi salvo pela interface.
#
# Consequencia: este .env e arquivo de ESTADO, nao so de configuracao. Entra no
# backup e nao deve ser recriado do zero num redeploy, senao as chaves de LLM
# cadastradas pela interface se perdem.
# ─────────────────────────────────────────────────────────────────────────────

CATALOG_BASE_URL=http://localhost:8088
GENERATOR_REQUIRE_AUTH=true
GENERATOR_API_KEY=troque-esta-chave

# Hosts para os quais a chave da LLM pode ser enviada. Deixe vazio para usar o
# padrao (principais provedores). Use https://; http:// so em localhost.
LLM_ALLOWED_HOSTS=
LLM_TIMEOUT_MS=60000

# Ligue APENAS se o gerador estiver atras de um proxy reverso (nginx, Traefik).
# Com true, o limite de tentativas de login usa o IP do x-forwarded-for em vez do
# IP do proxy - sem isso, um atacante tranca o acesso de todo mundo. Em exposicao
# direta deixe false, porque o header e forjavel.
TRUST_PROXY=false

# ── Grupo 2: gerenciado pela tela de configuracao do gerador ──
# Da daqui para baixo, a interface sobrescreve os valores ao salvar. Edite a mao
# so para o primeiro setup ou para recuperar um ambiente.
LLM_ACTIVE_SLOT=1
LLM_MODEL=gpt-4.1-mini
LLM_API_URL=https://api.openai.com/v1/chat/completions
LLM_API_KEY=
OPENAI_API_KEY=

LLM_SLOT_1_LABEL=OpenAI Principal
LLM_SLOT_1_MODEL=gpt-4.1-mini
LLM_SLOT_1_API_URL=https://api.openai.com/v1/chat/completions
LLM_SLOT_1_API_KEY=

LLM_SLOT_2_LABEL=API 2
LLM_SLOT_2_MODEL=gpt-4.1-mini
LLM_SLOT_2_API_URL=https://api.openai.com/v1/chat/completions
LLM_SLOT_2_API_KEY=

LLM_SLOT_3_LABEL=API 3
LLM_SLOT_3_MODEL=gpt-4.1-mini
LLM_SLOT_3_API_URL=https://api.openai.com/v1/chat/completions
LLM_SLOT_3_API_KEY=

LLM_SLOT_4_LABEL=API 4
LLM_SLOT_4_MODEL=gpt-4.1-mini
LLM_SLOT_4_API_URL=https://api.openai.com/v1/chat/completions
LLM_SLOT_4_API_KEY=

LLM_SLOT_5_LABEL=API 5
LLM_SLOT_5_MODEL=gpt-4.1-mini
LLM_SLOT_5_API_URL=https://api.openai.com/v1/chat/completions
LLM_SLOT_5_API_KEY=
